<%= javascript_tag do %>
  document.addEventListener('DOMContentLoaded', function() {
    // Protein threshold handler
    document.getElementById('protein-threshold')?.addEventListener('change', function(e) {
      const threshold = e.target.value;
      window.location.href = '<%= dining_hall_path(@dining_hall) %>?protein_threshold=' + threshold;
    });

    // Sortable headers handler
    document.querySelectorAll('.sortable').forEach(header => {
      header.addEventListener('click', function() {
        const sortBy = this.dataset.sort;
        let sortDirection = 'desc';
        
        if (sortBy === '<%= @sort_by %>') {
          sortDirection = '<%= @sort_direction %>' === 'desc' ? 'asc' : 'desc';
        }
        
        const url = new URL(window.location.href);
        url.searchParams.set('sort_by', sortBy);
        url.searchParams.set('sort_direction', sortDirection);
        window.location.href = url.toString();
      });
    });
  });
<% end %>

<style>
  .sortable {
    cursor: pointer;
    user-select: none;
  }
  .sortable:hover {
    background-color: #f8f9fa;
  }
  .bi {
    margin-left: 5px;
  }
</style>
